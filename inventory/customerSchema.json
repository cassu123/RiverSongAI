{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Customer",
  "type": "object",
  "description": "Database structure for CRM integration representing a customer in the Vault.",
  "properties": {
    "customer_id": {
      "type": "string",
      "description": "Unique identifier, formatted to be compatible with Shopify GraphQL Admin API (e.g., gid://shopify/Customer/12345)"
    },
    "first_name": {
      "type": "string"
    },
    "last_name": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "phone": {
      "type": "string"
    },
    "social_handles": {
      "type": "object",
      "properties": {
        "instagram": { "type": "string" },
        "tiktok": { "type": "string" },
        "twitter": { "type": "string" }
      }
    },
    "personal_notes": {
      "type": "string",
      "description": "e.g., 'Prefers citrus scents', 'Usually a size Large'"
    },
    "loyalty_points": {
      "type": "integer",
      "description": "Calculated as $1 = 1 point",
      "default": 0
    },
    "purchase_history": {
      "type": "array",
      "description": "Full purchase history of the customer",
      "items": {
        "type": "object",
        "properties": {
          "transaction_id": { "type": "string" },
          "date": { "type": "string", "format": "date-time" },
          "total_amount": { "type": "number" },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "product_id": { "type": "string" },
                "sku": { "type": "string" },
                "quantity": { "type": "integer" },
                "price_at_sale": { "type": "number" }
              },
              "required": ["product_id", "quantity", "price_at_sale"]
            }
          }
        },
        "required": ["transaction_id", "date", "total_amount"]
      }
    },
    "shopify_sync_status": {
      "type": "boolean",
      "default": false,
      "description": "Flag to identify which local records have been successfully pushed to the external Shopify storefront"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["customer_id", "first_name", "shopify_sync_status"]
}