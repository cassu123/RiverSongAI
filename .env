# Minimal .env to start the backend for UI testing.
# Providers that require hardware (Whisper, Piper, Ollama) will error only
# when a conversation turn is triggered -- the server and UI load fine without them.

APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173"]

STT_PROVIDER=whisper_local
WHISPER_MODEL_SIZE=base
AUDIO_INPUT_DEVICE=

LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1:8b
RIVER_SONG_SYSTEM_PROMPT=You are River Song, a confident and witty AI assistant with a warm personality. Be concise and helpful.
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.7

TTS_PROVIDER=piper
PIPER_EXECUTABLE_PATH=/usr/local/bin/piper
PIPER_MODEL_PATH=
AUDIO_OUTPUT_DEVICE=

KILL_SWITCH_PASSWORD_HASH=

GOOGLE_CLIENT_SECRETS_PATH=config_files/google_client_secrets.json
GOOGLE_TOKEN_STORAGE_PATH=data/google_tokens
GOOGLE_MAPS_API_KEY=

INTENT_CONFIDENCE_THRESHOLD=0.7
DEFAULT_USER_ID=primary_user

HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=
DEVICE_REGISTRY_PATH=config_files/device_registry.json

WEATHER_API_KEY=
DEFAULT_LOCATION=New York,US
WEATHER_UNITS=imperial
NEWS_API_KEY=
ALPHA_VANTAGE_API_KEY=
SPORTS_API_KEY=1
