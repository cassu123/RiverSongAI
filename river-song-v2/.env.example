# =============================================================================
# River Song AI -- Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# Every provider is swappable by changing a single line.
# =============================================================================


# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------

# Host and port for the FastAPI backend
APP_HOST=0.0.0.0
APP_PORT=8000

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Comma-separated list of allowed CORS origins (your frontend dev server)
CORS_ORIGINS=http://localhost:5173


# -----------------------------------------------------------------------------
# STT (SPEECH-TO-TEXT) PROVIDER
# -----------------------------------------------------------------------------
# Supported values: whisper_local
# Future values: whisper_cloud, deepgram

STT_PROVIDER=whisper_local

# Whisper model size: tiny | base | small | medium | large
# Larger models are more accurate but slower and use more VRAM.
WHISPER_MODEL_SIZE=base

# Audio input device index. Leave blank to use system default.
# Run `python -c "import sounddevice as sd; print(sd.query_devices())"` to list devices.
AUDIO_INPUT_DEVICE=


# -----------------------------------------------------------------------------
# LLM (LANGUAGE MODEL) PROVIDER
# -----------------------------------------------------------------------------
# Supported values: ollama
# Future values: openai, anthropic, groq

LLM_PROVIDER=ollama

# Ollama base URL (default assumes Ollama running locally)
OLLAMA_BASE_URL=http://localhost:11434

# Model to use via Ollama. Must be pulled first: `ollama pull llama3.1:8b`
LLM_MODEL=llama3.1:8b

# System prompt for River Song's personality
RIVER_SONG_SYSTEM_PROMPT=You are River Song, a confident and witty AI assistant with a warm personality. Be concise and helpful.

# Maximum tokens to generate per response
LLM_MAX_TOKENS=512

# LLM temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.7


# -----------------------------------------------------------------------------
# TTS (TEXT-TO-SPEECH) PROVIDER
# -----------------------------------------------------------------------------
# Supported values: piper
# Future values: elevenlabs, coqui, openai_tts

TTS_PROVIDER=piper

# Absolute path to the Piper executable on your system
PIPER_EXECUTABLE_PATH=/usr/local/bin/piper

# Absolute path to the Piper voice model file (.onnx)
PIPER_MODEL_PATH=/home/user/.local/share/piper/en_US-lessac-medium.onnx

# Audio output device index. Leave blank to use system default.
AUDIO_OUTPUT_DEVICE=


# -----------------------------------------------------------------------------
# KILL SWITCH
# -----------------------------------------------------------------------------
# bcrypt hash of the password required to reset the kill switch.
# Generate with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
KILL_SWITCH_PASSWORD_HASH=


# -----------------------------------------------------------------------------
# GOOGLE SERVICES (Phase 2)
# -----------------------------------------------------------------------------
# OAuth 2.0 client secrets JSON downloaded from Google Cloud Console.
# Set up at: https://console.cloud.google.com/ -> APIs & Services -> Credentials
# Download the "Desktop app" OAuth client JSON and place it at this path.
GOOGLE_CLIENT_SECRETS_PATH=config_files/google_client_secrets.json

# Directory where per-user OAuth tokens are persisted between restarts.
# Created automatically on first authorization. Never commit this directory.
GOOGLE_TOKEN_STORAGE_PATH=data/google_tokens

# Google Maps Platform API key.
# Enable at: https://console.cloud.google.com/ -> APIs & Services -> Enable Maps JavaScript API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key


# -----------------------------------------------------------------------------
# INTENT ROUTER (Phase 2)
# -----------------------------------------------------------------------------
# Minimum confidence score (0.0 - 1.0) required to route to a Google provider.
# Below this threshold the transcript falls through to the Ollama conversation path.
INTENT_CONFIDENCE_THRESHOLD=0.7

# Default user ID used for Google OAuth token lookups.
# Must match the user_id passed to authorize_user() during initial OAuth flow.
DEFAULT_USER_ID=primary_user
