# This is a sample .gitignore file for a Python project with AI/ML components.
# It includes common ignores for Python, OS, IDEs, and large files.

# Python specific ignores
*.py[cod]
*$py.class
__pycache__/
.Python/
build/
develop-eggs/
dist/
eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.sqlite3
*.db
.coverage
.pytest_cache/
htmlcov/
.nox/

# Virtual Environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.direnv/
.pip-modules/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS and IDE specific ignores
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.vscode/
*.sublime-workspace
*.idea/
.project
.settings/
.classpath

# Compiled/binary files (from AI models, logs, etc.)
*.log
*.sqlite
*.jsonl
# Only ignore if these are large generated data files, not source data you want to track
# *.csv
# *.txt

# Environment variables and sensitive files
.env
.flaskenv
instance/

# Specific credentials and configuration files
*client_secrets.json
*config.json
*.oauth2.credentials

# Generated outputs and tree files
output.txt
project_tree.txt

# Specific project directories for data/logs/models
data/
logs/
models/
