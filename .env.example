# =============================================================================
# River Song AI -- Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# Every provider is swappable by changing a single line.
# =============================================================================


# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------

# Host and port for the FastAPI backend
APP_HOST=0.0.0.0
APP_PORT=8000

# Runtime environment: development | production
# Controls whether /docs and /redoc are exposed.
ENVIRONMENT=production

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=["https://yourdomain.com"]

# Trusted hostnames (your domain + any subdomains). Prevents Host header attacks.
# Set to ["*"] only for local dev.
ALLOWED_HOSTS=["yourdomain.com","www.yourdomain.com"]


# -----------------------------------------------------------------------------
# STT (SPEECH-TO-TEXT) PROVIDER
# -----------------------------------------------------------------------------
# Supported values: whisper_local
# Future values: whisper_cloud, deepgram

STT_PROVIDER=whisper_local

# Whisper model size: tiny | base | small | medium | large
# Larger models are more accurate but slower and use more VRAM.
WHISPER_MODEL_SIZE=base

# Audio input device index. Leave blank (audio is captured in the browser, not server-side).
AUDIO_INPUT_DEVICE=


# -----------------------------------------------------------------------------
# LLM (LANGUAGE MODEL) PROVIDER
# -----------------------------------------------------------------------------
# Supported values: ollama | anthropic | gemini | openai | mistral_ai
# Cloud providers require the corresponding API key and _ENABLED=true below.

LLM_PROVIDER=ollama

# Ollama base URL (default assumes Ollama running locally on your Linux machine)
OLLAMA_BASE_URL=http://localhost:11434

# Model ID for the selected provider.
# Ollama examples:  llama3.2:3b  |  deepseek-r1:1.5b  |  phi3.5  |  gemma3:4b
# Anthropic:        claude-haiku-4-5-20251001  |  claude-sonnet-4-6
# Gemini:           gemini-2.0-flash  |  gemini-2.5-flash-preview-04-17
# OpenAI:           gpt-4o-mini  |  gpt-4o
# Mistral AI:       mistral-small-latest  |  mistral-large-latest
LLM_MODEL=llama3.2:3b

# System prompt for River Song's personality
RIVER_SONG_SYSTEM_PROMPT=You are River Song, a confident and witty AI assistant with a warm personality. Be concise and helpful.

# Maximum tokens to generate per response
LLM_MAX_TOKENS=512

# LLM temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.7

# Enable real-time token streaming for local Ollama responses (Phase 2)
LLM_STREAMING_ENABLED=true

# LLM Tool Use (Phase 3)
TOOL_USE_ENABLED=false
TOOL_USE_PROVIDER=anthropic

# Local Vision Model (Phase 4)
# Use moondream for lightweight (4GB VRAM) or llava for higher quality.
# Set VISION_ENABLED=true and run: ollama pull moondream
VISION_MODEL=moondream
VISION_ENABLED=false

# --- Cloud LLM API Keys ---
# Leave blank if you are not using that provider.
# WARNING: Cloud LLMs cost money per token. Enable only what you intend to use.

# Anthropic Claude -- console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_ENABLED=false

# Google Gemini -- aistudio.google.com
GEMINI_API_KEY=
GEMINI_ENABLED=false

# OpenAI -- platform.openai.com
OPENAI_API_KEY=
OPENAI_ENABLED=false

# Mistral AI -- console.mistral.ai
MISTRAL_API_KEY=
MISTRAL_AI_ENABLED=false


# Amazon Bedrock
# IAM user needs: bedrock:InvokeModelWithResponseStream
# Enable model access at: console.aws.amazon.com -> Bedrock -> Model access
# Supported models: Nova Micro/Lite/Pro, Claude 3/3.5, Llama 3.1/3.3, DeepSeek R1, Mistral Large
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_ENABLED=false
BEDROCK_DEFAULT_MODEL=amazon.nova-lite-v1:0


# -----------------------------------------------------------------------------
# TTS (TEXT-TO-SPEECH) PROVIDER
# -----------------------------------------------------------------------------
# Supported values: piper
# Future values: elevenlabs, coqui, openai_tts

TTS_PROVIDER=piper

# Absolute path to the Piper executable on your system
PIPER_EXECUTABLE_PATH=/usr/local/bin/piper

# ── Web Search (Free Fallback Chain) ──────────────────────────────────
# River Song tries these in order. Configure as many as you like.
# She never pays for searches — all free tiers, no card required.
#
# 1. SearXNG (UNLIMITED — best option, run scripts/start_searxng.sh)
SEARXNG_BASE_URL=http://localhost:8080
#
# 2. Tavily — 1,000 free/month — sign up free at tavily.com
TAVILY_API_KEY=
#
# 3. Google PSE — 100 free/day
#    Create engine: programmablesearchengine.google.com
#    Get API key:   console.cloud.google.com → Custom Search API
GOOGLE_PSE_API_KEY=
GOOGLE_PSE_CX=
#
# 4. TinyFish — 5 free/min — sign up free at tinyfish.io (no card)
TINYFISH_API_KEY=

# Absolute path to the Piper voice model file (.onnx)
PIPER_MODEL_PATH=/home/user/.local/share/piper/en_US-lessac-medium.onnx

# ElevenLabs TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=            # Your ElevenLabs voice clone ID (e.g. 21m00Tcm4TlvDq8ikWAM)
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ── Push Notifications ────────────────────────────────────────────────
# Generate VAPID keys once and paste here:
#   pip install pywebpush
#   python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys();
#              print('PRIVATE:', v.private_key.decode());
#              print('PUBLIC:', v.public_key.decode())"
PUSH_NOTIFICATIONS_ENABLED=false
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=mailto:you@example.com

# ── Startup Greeting ──────────────────────────────────────────────────
# River checks your calendar when you open the app
STARTUP_BRIEFING_ENABLED=true
STARTUP_BRIEFING_HOURS_AHEAD=8

# Audio output device index. Leave blank to use system default.
AUDIO_OUTPUT_DEVICE=


# -----------------------------------------------------------------------------
# KILL SWITCH
# -----------------------------------------------------------------------------
# bcrypt hash of the password required to reset the kill switch.
# Generate with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
KILL_SWITCH_PASSWORD_HASH=


# -----------------------------------------------------------------------------
# GOOGLE SERVICES (Phase 2)
# -----------------------------------------------------------------------------
# OAuth 2.0 client secrets JSON downloaded from Google Cloud Console.
# Set up at: https://console.cloud.google.com/ -> APIs & Services -> Credentials
# Download the "Desktop app" OAuth client JSON and place it at this path.
GOOGLE_CLIENT_SECRETS_PATH=config_files/google_client_secrets.json

# Directory where per-user OAuth tokens are persisted between restarts.
# Created automatically on first authorization. Never commit this directory.
GOOGLE_TOKEN_STORAGE_PATH=data/google_tokens

# Google Maps Platform API key.
# Enable at: https://console.cloud.google.com/ -> APIs & Services -> Enable Maps JavaScript API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key


# -----------------------------------------------------------------------------
# HOME ASSISTANT (Phase 3)
# -----------------------------------------------------------------------------
# URL of your Home Assistant instance. LAN address preferred over cloud relay.
HOME_ASSISTANT_URL=http://homeassistant.local:8123

# Long-lived access token generated in HA: Profile -> Security -> Long-lived access tokens.
# Never commit this value. Treat it like a password.
HOME_ASSISTANT_TOKEN=your_long_lived_access_token

# Path to the device registry JSON file that maps plain-English names to HA entity IDs.
# Copy config_files/device_registry.example.json to this path and fill in your entities.
DEVICE_REGISTRY_PATH=config_files/device_registry.json


# -----------------------------------------------------------------------------
# INFORMATION FEEDS (Phase 5)
# -----------------------------------------------------------------------------

# OpenWeatherMap API key (free tier sufficient).
# Register at: https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key

# Default location for weather queries when no location is spoken.
# Format: "City,CountryCode" (e.g., "Chicago,US" or "London,GB")
DEFAULT_LOCATION=New York,US

# Temperature units for weather output: imperial (Fahrenheit) or metric (Celsius)
WEATHER_UNITS=imperial

# NewsAPI.org key (free tier: 100 requests/day, headlines only in production).
# Register at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key

# Alpha Vantage key for stock quotes (free tier: 25 requests/day).
# Register at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# TheSportsDB API key. Free tier uses the literal value "1".
# Upgrade at: https://www.thesportsdb.com/api.php for more endpoints.
SPORTS_API_KEY=1


# -----------------------------------------------------------------------------
# COMMERCE AUTOMATION (Phase 8)
# -----------------------------------------------------------------------------

# --- Amazon Selling Partner API (SP-API) ---
# Full setup guide: docs/api_registry/amazon_seller.txt
# Register your developer app at: https://developer.amazon.com/seller

# LWA (Login with Amazon) credentials -- from your developer app
AMAZON_SP_LWA_APP_ID=your_lwa_client_id
AMAZON_SP_LWA_CLIENT_SECRET=your_lwa_client_secret

# LWA refresh token -- generated when you authorize the app as a seller.
# Seller Central -> Apps & Services -> Manage Your Apps -> Authorize
AMAZON_SP_REFRESH_TOKEN=your_lwa_refresh_token

# AWS IAM credentials for SigV4 request signing
# Create an IAM user with AmazonSPAPISellerFull policy
AMAZON_AWS_ACCESS_KEY=your_aws_access_key
AMAZON_AWS_SECRET_KEY=your_aws_secret_key

# Your seller account ID (visible in Seller Central -> Account Info)
AMAZON_SELLER_ID=your_seller_id

# Marketplace ID. US default shown. Other regions: see docs/api_registry/amazon_seller.txt
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER

# Units at or below this count trigger a low-stock alert
AMAZON_LOW_STOCK_THRESHOLD=5


# --- Walmart Marketplace Seller API ---
# Full setup guide: docs/api_registry/walmart_seller.txt
# Register at: https://developer.walmart.com/

WALMART_CLIENT_ID=your_walmart_client_id
WALMART_CLIENT_SECRET=your_walmart_client_secret
WALMART_LOW_STOCK_THRESHOLD=5


# -----------------------------------------------------------------------------
# ANALYTICS PLATFORM INTEGRATIONS
# -----------------------------------------------------------------------------

# Analytics page is currently manual snapshot entry only. Real platform 
# integrations for TikTok / Instagram / Facebook / YouTube / Etsy / eBay / 
# Shopify / Pinterest / Twitter are tracked in docs/future_updates/roadmap.md 
# and not implemented in code.



# -----------------------------------------------------------------------------
# READING PROVIDERS (Phase 6)
# -----------------------------------------------------------------------------

# Audible: base directory for per-user auth files ({user_id}.json).
# Run setup once per user: python -m providers.reading.audible --setup --user-id primary_user
# This directory is gitignored automatically (lives inside data/).
AUDIBLE_AUTH_BASE_PATH=data/audible

# Audible marketplace. Match this to the country where you bought your books.
# Options: us | uk | de | fr | es | it | jp | au | ca | in
AUDIBLE_COUNTRY_CODE=us

# Libby/OverDrive: base directory for per-user chip files ({user_id}.json).
# Run setup once per user: python -m providers.reading.libby --setup --user-id primary_user
# You will need the Libby app to generate an 8-digit pairing code.
# This directory is gitignored automatically (lives inside data/).
LIBBY_CHIP_BASE_PATH=data/libby


# -----------------------------------------------------------------------------
# MEMORY / DATABASE (Phase 1)
# -----------------------------------------------------------------------------

# Path to the SQLite database file. Created automatically on first run.
# Change this to an absolute path on your Linux machine if preferred.
DB_PATH=data/river_song.db

# Paths for the other SQLite databases (all live in data/ by default)
COMMERCE_DB_URL=sqlite:///./data/commerce.db
INVENTORY_DB_URL=sqlite:///./data/inventory.db
VEHICLES_DB_URL=sqlite:///./data/vehicles.db
MAIN_DB_PATH=./data/river_song.db

# Generate and store conversation summaries at the end of each session.
# Set to false to disable summaries entirely (facts and preferences still work).
MEMORY_SUMMARIES_ENABLED=true

# Default TTL for conversation summaries.
# Options: short (7 days) | standard (30 days) | extended (90 days) | long (365 days) | forever
MEMORY_DEFAULT_TTL=standard

# Automatically reset a summary's expiry from today each time it is referenced.
# Frequently-used summaries survive longer naturally under this rule.
MEMORY_AUTO_EXTEND=true

# Maximum number of recent summaries injected into the LLM context per turn.
MEMORY_MAX_SUMMARIES_IN_CONTEXT=10

# Semantic memory (Phase 1)
# Uses Ollama for embeddings and ChromaDB for vector storage.
# Set SEMANTIC_MEMORY_ENABLED=true and run: ollama pull nomic-embed-text
EMBEDDING_MODEL=nomic-embed-text
CHROMA_PATH=/mnt/data/river-song/chroma
SEMANTIC_MEMORY_ENABLED=true


# -----------------------------------------------------------------------------
# INTENT ROUTER (Phase 2+)
# -----------------------------------------------------------------------------
# Minimum confidence score (0.0 - 1.0) required to route to a Google provider.
# Below this threshold the transcript falls through to the Ollama conversation path.
INTENT_CONFIDENCE_THRESHOLD=0.7

# Default user ID used for Google OAuth token lookups.
# Must match the user_id passed to authorize_user() during initial OAuth flow.
DEFAULT_USER_ID=primary_user


# -----------------------------------------------------------------------------
# DAEMON INFRASTRUCTURE
# -----------------------------------------------------------------------------

# Shared secret used by daemons to authenticate their heartbeat and internal API calls.
# MUST be set in .env. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
DAEMON_INTERNAL_SECRET=

# Internal ports for background daemons. Bound to 127.0.0.1 exclusively.
DAEMON_WARDEN_PORT=8010
DAEMON_MECHANIC_PORT=8011
DAEMON_HERALD_PORT=8012
DAEMON_SIFTER_PORT=8013
DAEMON_NAVIGATOR_PORT=8014
DAEMON_CHEMIST_PORT=8015

# --- Warden (Security / Vision) ---
WARDEN_ENABLED=false
# JSON mapping of room names to RTSP camera streams.
WARDEN_RTSP_CAMERAS={"living_room": "", "kitchen": ""}
# YOLO object detection settings.
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.5
YOLO_INFERENCE_DEVICE=cpu

# --- Herald (Hub Casting / Announcements) ---
HERALD_ENABLED=false
# JSON array of Home Assistant media_player entity IDs (e.g. Google Home Hubs).
HUB_ENTITIES=[]
# The URL that Herald will persistently cast to Hub displays.
KIOSK_URL=http://localhost:8000/kiosk

# --- Mechanic (ArduRover Telemetry) ---
MECHANIC_ENABLED=false
# Serial port for the MAVLink radio (e.g. /dev/ttyUSB0 or /dev/ttyACM0).
MAVLINK_SERIAL_PORT=/dev/ttyUSB0
MAVLINK_BAUD_RATE=57600

# --- Sifter (Background Document RAG) ---
SIFTER_ENABLED=false
# Absolute path to the directory where Sifter should look for documents to index.
WAPS_DOCUMENTS_PATH=/mnt/data/river-song/waps
